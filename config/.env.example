# ════════════════════════════════════════════════════════════
# BlueSentinel V2.0 — Configuration Template
# Copy this file to .env and fill in your values
# NEVER commit .env to git
# ════════════════════════════════════════════════════════════

# ── AI Provider ──────────────────────────────────────────────
# Choose: openai | anthropic
AI_PROVIDER=openai

# OpenAI (required if AI_PROVIDER=openai)
OPENAI_API_KEY=sk-proj-your-key-here
OPENAI_MODEL=gpt-4o

# Anthropic Claude (required if AI_PROVIDER=anthropic)
ANTHROPIC_API_KEY=sk-ant-your-key-here
ANTHROPIC_MODEL=claude-sonnet-4-5

# ── Threat Intelligence APIs ─────────────────────────────────
# VirusTotal — comma-separated for key rotation (free: 500 req/day per key)
VIRUSTOTAL_API_KEYS=your-vt-key-1,your-vt-key-2

# AbuseIPDB — https://www.abuseipdb.com/register
ABUSEIPDB_API_KEY=your-abuseipdb-key

# AlienVault OTX — https://otx.alienvault.com/
OTX_API_KEY=your-otx-key

# Shodan — https://account.shodan.io (optional)
SHODAN_API_KEY=your-shodan-key

# MISP — optional, for enterprise threat intel
MISP_URL=https://your-misp-instance.local
MISP_KEY=your-misp-auth-key

# ── Dashboard ────────────────────────────────────────────────
DASHBOARD_USERNAME=admin
DASHBOARD_PASSWORD=change-this-to-a-strong-password
DASHBOARD_PORT=5000

# ── News Feed (optional) ─────────────────────────────────────
# Free tier: 100 req/day — https://newsapi.org/register
# Leave blank to use RSS feeds (no key required)
NEWS_API_KEY=

# ── SIEM Integration (optional) ──────────────────────────────
SIEM_HOST=
SIEM_PORT=514
SIEM_PROTOCOL=udp
